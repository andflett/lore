# Copy to .env.local and fill in your keys: cp .env.example .env.local
#
# The app is fully functional with just GROQ_API_KEY + TAVILY_API_KEY.
# ANTHROPIC_API_KEY is optional — without it, Claude models fall back to Groq.

# Groq — free tier, generous limits. Powers the default model (gpt-oss-120b).
# https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Tavily — web/wiki search. Required for the search + citations feature.
# Free tier available. https://app.tavily.com
TAVILY_API_KEY=tvly_...

# Anthropic — optional. Enables Claude (Haiku/Sonnet) for higher-quality
# answers + prompt caching. Pay-as-you-go; Claude Pro does NOT include API
# access. https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────────────────────────────────
# Demo usage limiting (OPTIONAL — for a public hosted demo only).
# Leave all of these unset to run unlimited (self-host / local dev).
# When set, pure-demo requests (no user-supplied key) are capped per day;
# BYOK requests always bypass. https://console.upstash.com (free tier)
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# DEMO_DAILY_USER_LIMIT=15      # per-browser soft cap (default 15)
# DEMO_DAILY_GLOBAL_LIMIT=300   # global kill-switch — protects Tavily (default 300)
